# Copy this file to .env and fill in your values.
# Never commit .env to version control.

DATABASE_URL=postgresql://user:password@host:5432/dbname

YOUTUBE_CLIENT_ID=your-google-oauth-client-id
YOUTUBE_CLIENT_SECRET=your-google-oauth-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

ORDINAL_API_KEY=your-ordinal-api-key

# Do NOT set ANTHROPIC_API_KEY — this repo uses claude -p (subscription auth).
# Setting it will raise a RuntimeError at startup.

# Unique identifier for this client account (e.g. company slug). Used to scope all data.
CLIENT_ID=acme-corp

# Maps Ordinal profile display names to client_id slugs.
# Add a new entry for each client whose profile is connected to your Ordinal account.
# Profiles not listed fall back to CLIENT_ID.
ORDINAL_PROFILE_CLIENTS={"Your Name": "your-slug", "Client Name": "client-slug"}
